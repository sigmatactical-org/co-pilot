# vehicle.service — sim on QEMU, SocketCAN on hardware
SIGMARACER_WINGMAN_VEHICLE_SOURCE=sim
SIGMARACER_WINGMAN_VEHICLE_DEMO=1
SIGMARACER_WINGMAN_TELEMETRY_SOCKET=/run/sigmaracer-wingman/vehicle.sock
# Uncomment to capture decoded CAN frames as MDF4 (requires writable path):
# SIGMARACER_WINGMAN_CAN_LOG_PATH=/var/log/sigmaracer-wingman/can.mf4
