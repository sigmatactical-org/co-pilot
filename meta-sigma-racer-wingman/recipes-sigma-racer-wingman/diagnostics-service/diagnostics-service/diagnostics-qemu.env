# sigma-telemetry-relay — QEMU/dev image (slirp host -> guest 127.0.0.1).
TELEMETRY_RELAY_PORT=7357
TELEMETRY_RELAY_LISTEN=0.0.0.0:7357
TELEMETRY_RELAY_SOCKET=/run/sigma-racer-wingman/vehicle.sock
TELEMETRY_TLS_CA=/etc/sigma-racer-wingman/telemetry-tls/ca.pem
TELEMETRY_TLS_CERT=/etc/sigma-racer-wingman/telemetry-tls/server.pem
TELEMETRY_TLS_KEY=/etc/sigma-racer-wingman/telemetry-tls/server.key
