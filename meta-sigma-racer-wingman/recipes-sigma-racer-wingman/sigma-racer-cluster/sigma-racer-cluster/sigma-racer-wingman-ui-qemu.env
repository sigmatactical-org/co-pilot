# QEMU virt panel — fixed 800×480 (matches sigma-racer-wingman-qemu / imx8mp panel)
WAYLAND_DISPLAY=/run/weston/wayland-0
XDG_RUNTIME_DIR=/run/user/cluster
SLINT_BACKEND=winit-femtovg
SLINT_FULLSCREEN=0
SIGMA_PANEL_WIDTH=800
SIGMA_PANEL_HEIGHT=480
SIGMA_DISPLAY_MODE=night
SIGMA_RACER_WINGMAN_TELEMETRY_SOCKET=/run/sigma-racer-wingman/vehicle.sock
