# Instrumentation / sigma-racer-cluster runtime (sole UI)
# Weston socket (see weston-qemu.service: XDG_RUNTIME_DIR=/run/weston)
WAYLAND_DISPLAY=/run/weston/wayland-0
XDG_RUNTIME_DIR=/run/user/cluster
SLINT_BACKEND=femtovg
SLINT_FULLSCREEN=1
# Design canvas is 800×480 — keep logical == physical on the panel.
SLINT_SCALE_FACTOR=1
SIGMA_DISPLAY_MODE=night
SIGMA_RACER_WINGMAN_TELEMETRY_SOCKET=/run/sigma-racer-wingman/vehicle.sock
