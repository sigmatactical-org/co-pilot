# POKY_BBLAYERS_CONF_VERSION is increased each time build/conf/bblayers.conf
# structure changes
POKY_BBLAYERS_CONF_VERSION = "2"

BBPATH = "${TOPDIR}"
BBFILES ?= ""

#
# Virtual target layers — no NXP / Freescale BSP required
#
SIGMARACER_WINGMAN_ROOT ??= "${TOPDIR}/../.."

BBLAYERS ?= " \
    ${SIGMARACER_WINGMAN_ROOT}/meta-sigmaracer-wingman \
    ${SIGMARACER_WINGMAN_ROOT}/../poky/meta \
    ${SIGMARACER_WINGMAN_ROOT}/../poky/meta-poky \
    ${SIGMARACER_WINGMAN_ROOT}/../poky/meta-yocto-bsp \
    ${SIGMARACER_WINGMAN_ROOT}/../meta-openembedded/meta-oe \
    ${SIGMARACER_WINGMAN_ROOT}/../meta-openembedded/meta-multimedia \
    ${SIGMARACER_WINGMAN_ROOT}/../meta-openembedded/meta-networking \
    ${SIGMARACER_WINGMAN_ROOT}/../meta-openembedded/meta-python \
    ${SIGMARACER_WINGMAN_ROOT}/../meta-openembedded/meta-filesystems \
    ${SIGMARACER_WINGMAN_ROOT}/../meta-rust \
    ${SIGMARACER_WINGMAN_ROOT}/../meta-clang \
    ${SIGMARACER_WINGMAN_ROOT}/../meta-rauc \
"
